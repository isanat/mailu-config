# ============================================
# Mailu Environment Configuration
# travelconcierge.site
# ============================================

# ==========================================
# CONFIGURAÇÕES BÁSICAS
# ==========================================

# Chave secreta para sessões (GERADA AUTOMATICAMENTE)
# Gere uma nova com: openssl rand -hex 16
SECRET_KEY=Tr4v3lC0nc13rg3M41lUS3cr3tK3y2024!@#$

# Domínio principal
DOMAIN=travelconcierge.site

# Hostnames do servidor de email
HOSTNAMES=mail.travelconcierge.site,travelconcierge.site

# Email do administrador
POSTMASTER=admin

# ==========================================
# REDE E BINDINGS
# ==========================================

# Bind addresses
BIND_ADDRESS4=0.0.0.0
BIND_ADDRESS6=::

# Redes confiáveis (rede interna do Docker)
RELAYNETS=192.168.203.0/24

# ==========================================
# RATE LIMITING (Limites de Envio)
# ==========================================

# Limite de mensagens por dia por usuário
MESSAGE_RATELIMIT=200/day

# Limite de destinatários por dia
RECIPIENT_RATELIMIT=1000/day

# Limite de tentativas de autenticação
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

# ==========================================
# TLS/SSL
# ==========================================

# Usar Let's Encrypt para certificados automáticos
TLS_FLAVOR=letsencrypt

# Email para notificações do Let's Encrypt
# TLS_CERT_EMAIL=admin@travelconcierge.site

# ==========================================
# LIMITES DE EMAIL
# ==========================================

# Tamanho máximo de emails (50MB)
MESSAGE_SIZE_LIMIT=52428800

# Quota padrão por usuário
DEFAULT_QUOTA=1G

# ==========================================
# INTERFACES WEB
# ==========================================

# Webmail a usar (snappymail ou roundcube)
WEBMAIL=snappymail

# Caminho do webmail
WEBROOT=/webmail

# Caminho do painel admin
ADMIN_PATH=/admin

# ==========================================
# ENDEREÇOS DOS SERVIÇOS
# ==========================================

# Redis
REDIS_HOST=redis

# Frontend
FRONT_ADDRESS=front

# SMTP
SMTP_ADDRESS=smtp
SMTP_PORT=25

# IMAP
IMAP_ADDRESS=imap
IMAP_PORT=993

# Antispam
ANTISPAM_ADDRESS=antispam

# Antivirus
ANTIVIRUS_ADDRESS=antivirus

# Webmail
WEBMAIL_ADDRESS=webmail

# Admin
ADMIN_ADDRESS=admin

# DNS Resolver
RESOLVER_ADDRESS=192.168.203.254

# ==========================================
# DATABASE
# ==========================================

# SQLite (simples, funciona bem para poucos usuários)
DB_SQLITE_FILE=/data/main.db

# ==========================================
# LOGGING
# ==========================================

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=WARNING

# ==========================================
# SEGURANÇA
# ==========================================

# Cookies seguros
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# Desabilitar estatísticas anônimas
DISABLE_STATISTICS=false

# ==========================================
# OPCIONAL: RECAPTCHA
# ==========================================

# Descomente para ativar proteção reCAPTCHA no login
# RECAPTCHA_PUBLIC_KEY=your-public-key
# RECAPTCHA_PRIVATE_KEY=your-private-key

# ==========================================
# OPCIONAL: DMARC REPORTING
# ==========================================

# Descomente para receber relatórios DMARC
# DMARC_RUA=admin@travelconcierge.site
# DMARC_RUF=admin@travelconcierge.site

# ==========================================
# OPCIONAL: WELCOME EMAIL
# ==========================================

# Enviar email de boas-vindas para novos usuários
WELCOME=false
WELCOME_SUBJECT=Bem-vindo ao Travel Concierge Mail!
WELCOME_BODY=Bem-vindo ao seu novo email do Travel Concierge!

# ==========================================
# OPCIONAL: FETCHMAIL
# ==========================================

# Buscar emails de outras contas
FETCHMAIL_ENABLED=false
